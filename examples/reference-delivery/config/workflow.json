      "id": "untriaged",
      "description": "human-filed issue awaiting triage by the architect"
    },
    {
      "id": "epic",
      "description": "identifies a long-lived epic issue"
    },
    {
      "id": "design",
      "description": "identifies a design issue"
    },
    {
      "id": "code",
      "description": "identifies a code issue"
    },
    {
      "id": "implementation",
      "description": "identifies an implementation pull request"
    },
    {
      "id": "draft",
      "description": "work item is still being shaped"
    },
    {
      "id": "ready",
      "description": "work item is ready for the next workflow step"
    },
    {
      "id": "in-progress",
