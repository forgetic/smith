{
  "name": "reference-delivery",
  "intake_author": { "kind": "role", "role": "human" },
  "roles": [
    {
      "id": "architect",
      "charter": "Turn requests into epics, design issues, and ready code issues; resolve needs-architect items; reconcile landed PRs.",
      "prompt": {
        "guidance": "Use triage_intake to triage untriaged intake. The triage workspace reads the issue and returns a verdict that the engine routes: ready_code rewrites the body into a crisp code spec, needs_design rewrites it into a design proposal, and needs_breakdown plans dependent child issues. Use reconcile_landed for landed implementation PRs."
      },
      "external_tools": [
        {
          "id": "triage_workspace",
          "description": "Read the intake issue and any linked context, then author either a rewritten body (code spec or design proposal) or a plan of dependent child issues, and return a verdict that routes the triage.",
          "required": false,
          "constraints": [
            "Only read the work-item context and repository; never mutate Forge state.",
            "Return one of the declared verdicts; the engine applies the routed transition's effects."
          ],
          "guidance": "Use this from triage_intake. If it is not bound, choose no_action for intake triage."
        }
      ],
      "concurrency": 1,
      "queues": [
        "design_triage",
        "needs_architect",
        "landed_inbox"
      ]
    },
    {
      "id": "engineer",
      "charter": "Claim ready code issues, implement them, open PRs, address failed review or CI gates, resolve merge conflicts, and escalate to the architect when a ready code issue cannot be implemented as specified.",
      "prompt": {
        "guidance": "Use open_pr for ready code: the coding workspace must produce a real product diff and the engine opens a PR from the head it produces. When the issue cannot be implemented as specified the workspace returns a needs_architect verdict, which routes open_pr to request_code_architect_input so the issue is escalated rather than looping on an empty diff. Use address_review_changes for PRs with changes requested, address_ci_failure for PRs whose CI failed before landing approval, address_landing_ci_failure for PRs whose landing-approved head later fails CI, and resolve_merge_conflict after pushing a conflict-resolution PR head."
      },
      "external_tools": [
        {
          "id": "coding_workspace",
          "description": "Prepare a checked-out repository workspace, make or delegate code edits, commit a PR head branch, and report changed files plus a short summary.",
          "required": false,
          "constraints": [
            "Only touch the checked-out repository workspace.",
            "Do not create bookkeeping-only diffs such as .temper-pr-prep or .temper-ci changes."
          ],
          "guidance": "Use this before open_pr for ready code issues. If it is not bound, choose no_action for code implementation work."
        }
      ],
      "concurrency": 3,
      "queues": [
        "code_ready",
        "pr_changes_requested",
        "pr_ci_failed",
        "pr_merge_conflict"
      ]
    },
    {
      "id": "reviewer",
      "charter": "Review PRs against the contract catalog by reading the real diff and CI; approve, request changes, or escalate.",
      "prompt": {
        "guidance": "Use review_pr to review a PR. The review workspace reads the real diff and CI result and returns a verdict the engine routes: approve queues mechanical landing, changes submits a native review carrying the authored review body, and escalate flags the architect. Decide from the diff and CI, not from the PR summary."
      },
      "external_tools": [
        {
          "id": "review_workspace",
          "description": "Read the pull request's real diff and CI result, judge it against the stated contract, and author a review body plus a verdict.",
          "required": false,
          "constraints": [
            "Read the diff and CI through the granted read capabilities; never mutate Forge state.",
            "Return one of the declared verdicts; the engine submits the native review and applies the routed effects."
          ],
          "guidance": "Use this from review_pr. If it is not bound, choose no_action for review work."
        }
      ],
      "concurrency": 2,
      "queues": [
        "pr_needs_review"
      ]
    },
    {
      "id": "owner",
      "charter": "Resolve needs-owner items and run holistic alignment review of landed cohorts; escalate to humans when needed.",
      "prompt": {
        "guidance": "Use review_alignment for landed PR alignment follow-up. Use request_human_input when owner judgment needs explicit human input."
      },
      "concurrency": 1,
      "queues": [
        "needs_owner",
        "owner_alignment"
      ]
    },
    {
      "id": "human",
      "charter": "Resolve needs-human items that require non-agent judgment.",
      "prompt": {
        "guidance": "Use clear_human_flag only after the needed human judgment has been supplied in the artifact context; otherwise choose no_action."
      },
      "concurrency": 1,
      "queues": [
        "needs_human"
      ]
    },
    {
      "id": "mechanical",
      "charter": "Automation authority used by the mechanical worker for landing and merge-conflict routing; do not bind this role to an LLM or role-decision process.",
      "prompt": {
        "guidance": "Automation-only role id for queue automation authorization. It is serviced by the mechanical worker, not by a role worker."
      },
      "concurrency": 1,
      "queues": []
    }
  ],
