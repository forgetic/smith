# reference-delivery example — operator-editable configuration (NO SECRETS).
#
# This file is sourced by run.sh. It carries only the knobs an operator may
# change; the launch script translates these into the production
# temper-worker / temper-provision-forgejo CLI flags. CLI overrides always win
# over what is set here, which in turn overrides the binaries' own defaults.
#
# Secrets (per-role tokens/passwords, any API key) never live here — see
# ../secrets/ and ../secrets/.env.example.

# --- Repository ---------------------------------------------------------------
# Legacy single-repo knobs. If REPOS is left empty, run.sh provisions and scans
# exactly OWNER/NAME. They remain useful for compatibility and quick one-repo
# smoke runs:
#   REPOS= ./run.sh start
OWNER=acme
NAME=service

# Repository set for the fixed worker pool. The checked-in demo uses two repos
# so one parent intake issue can fan out into per-repo child issues. Set REPOS=
# (empty) to fall back to the OWNER/NAME single-repo mode.
#
# Each worker token identity must have Forge permission on every configured
# repository. The worker's scan shard is not a write-authorization boundary;
# Forge permissions are.
REPOS="acme/service acme/service-canary"

# Cross-repo intake seeding. "auto" seeds one parent issue in the first repo
# when REPOS contains more than one repo, and seeds ordinary per-repo intakes in
# single-repo mode. Use 0 to demonstrate independent per-repo intakes instead.
CROSS_REPO_INTAKE=auto
CROSS_REPO_INTAKE_TITLE="Coordinate greeting across service and canary"

# Default branch the repo is initialized with (PRs target it).
DEFAULT_BRANCH=main

# --- Forgejo endpoint ---------------------------------------------------------
# Where the bundled Forgejo server listens. The example boots its OWN throwaway
# server on the loopback interface; 127.0.0.1 with a known local port is a sane
# default. To target a real Forgejo instead, point BASE_URL at it and drop the
# bundled-server/provisioning steps (see the README "Point it at your own
# Forgejo").
BASE_URL=http://127.0.0.1:3000

# --- Worker cadence / lifetime ------------------------------------------------
# Poll interval for each worker's level-triggered loop (--poll-ms), in
# milliseconds. Keep this long to prove webhooks are the latency accelerator;
# polling remains the liveness backstop if a webhook is lost.
POLL_MS=120000

# Enable the local webhook accelerator. Polling remains mandatory; when this is
# 0, workers run as polling-only exactly as before.
WEBHOOKS=1
TRIGGER_BIND=127.0.0.1:38080
WEBHOOK_URL=http://127.0.0.1:38080/forgejo/webhook

# Hard backstop on how long each worker process runs before exiting on its own
# (--run-secs). The launch script also stops workers via a stop-file sentinel;
# this is the belt-and-braces deadline. Budget several minutes for a full run.
RUN_SECS=600

# --- CPU cap (lesson 0009) ----------------------------------------------------
# The bundled Forgejo server (a Go program) can drive the host to several cores
# of sustained CPU under this multi-process workload. Cap GOMAXPROCS so the Go
# runtime cannot exceed this many cores. Set empty to opt out. Default 2.
TEMPER_FORGEJO_GOMAXPROCS=2

# --- Cached pinned binaries ---------------------------------------------------
# Absolute paths to the pinned Forgejo (7.0.12) and forgejo-runner (3.5.1)
# binaries. Leave empty to let the first run download + checksum them into
# .cache/forgejo/ (needs network to Codeberg / code.forgejo.org). On an
# offline/sandboxed host, pre-stage the binaries and point these at them.
TEMPER_FORGEJO_BINARY=
TEMPER_FORGEJO_RUNNER_BINARY=

# --- Temper entry-point binaries --------------------------------------------
# The example targets the operator-facing temper-production entry points rather
# than the temper-testing entry points. Leave empty for the workspace
# target/debug defaults. TEMPER_BUILD_PACKAGE is the package run.sh builds in
# the development profile unless TEMPER_SKIP_BUILD=1.
TEMPER_WORKER_BIN=
TEMPER_PROVISION_BIN=
TEMPER_TRIGGER_BIN=
TEMPER_VALIDATE_BIN=
TEMPER_BUILD_PACKAGE=temper-production

# --- Smith workflow-role decision process ------------------------------------
# Temper no longer ships in-process provider SDK agents. The launcher builds
# Smith's workflow-role decision responder and passes it through temper-worker's
# --role-decision-* process adapter flags. Provider/auth options are Smith-owned;
# the JSON below is copied verbatim to TEMPER_WORKER_ROLE_DECISION_ARGS_JSON.
REFERENCE_DELIVERY_ROLE_DECISION=smith
SMITH_WORKSPACE_ROOT=
SMITH_BUILD_PACKAGE=smith-temper-agent-cli
SMITH_WORKFLOW_ROLE_DECISION_BIN=
SMITH_WORKFLOW_ROLE_DECISION_ARGS_JSON='["--auth","chatgpt-oauth"]'
SMITH_WORKFLOW_ROLE_DECISION_ENV_ALLOWLIST=
SMITH_WORKFLOW_ROLE_DECISION_CWD=
SMITH_WORKFLOW_ROLE_DECISION_TIMEOUT_SECS=

# --- Optional coding workspace binding ---------------------------------------
# The bundled workflow declares the engineer's `coding_workspace` external tool.
# Leave these empty to keep the tool unbound; the generated prompt will say it is
# unavailable and the engineer should choose no_action for code implementation.
# Set them to a real checkout/provider command when validating meaningful PRs.
TEMPER_CODING_WORKSPACE_ROOT=
TEMPER_CODING_WORKSPACE_COMMAND=
TEMPER_CODING_WORKSPACE_REMOTE=origin
TEMPER_CODING_WORKSPACE_PUSH=1
TEMPER_CODING_WORKSPACE_PR_LABELS=implementation,needs-reviewer,needs-merge

# For Smith provider/auth setup, run Smith's documented preflight commands from
# the Smith checkout and edit SMITH_WORKFLOW_ROLE_DECISION_ARGS_JSON /
# allow-list above. Temper does not read provider auth files or secrets.
