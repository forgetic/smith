# Dogfood launcher config (no secrets). This file is sourced by run.sh.

BASE_URL=https://git.ekanayaka.io
REPO=ai/temper
SECRETS_SOURCE=$HOME/Documents/personal/forgejo-rhi

# Webhook tunnel: Forgejo on rhi calls http://127.0.0.1:39080, ssh -R forwards
# that remote loopback port back to the local trigger process.
SSH_HOST=rhi
LOCAL_TRIGGER_BIND=127.0.0.1:39080
REMOTE_WEBHOOK_HOST=127.0.0.1
REMOTE_WEBHOOK_PORT=39080
WEBHOOK_URL=http://127.0.0.1:39080/forgejo/webhook
WEBHOOKS=1

# Long poll is only the liveness backstop; webhooks should wake workers promptly.
# Live Forgejo webhooks on this instance do not reliably fire for every workflow
# label transition, so keep polling reasonably quick while still using webhook
# wakes when they arrive.
POLL_MS=10000

# Smith owns LLM provider/auth configuration for role decisions and the example
# product-manager interaction profile. Temper passes these opaque process
# arguments/env allow-lists to Smith through deployment bindings; run Smith's
# documented preflight when changing them.
DOGFOOD_ROLE_DECISION=smith
DOGFOOD_PRODUCT_CHAT_RESPONDER=smith
SMITH_WORKSPACE_ROOT=
SMITH_BUILD_PACKAGE=smith-temper-agent-cli
SMITH_WORKFLOW_ROLE_DECISION_BIN=
SMITH_WORKFLOW_ROLE_DECISION_ARGS_JSON='["--auth","chatgpt-oauth","--codex-model","gpt-5.5"]'
SMITH_WORKFLOW_ROLE_DECISION_ENV_ALLOWLIST=
SMITH_WORKFLOW_ROLE_DECISION_CWD=
SMITH_WORKFLOW_ROLE_DECISION_TIMEOUT_SECS=
SMITH_PRODUCT_MANAGER_RESPONDER_BIN=
SMITH_PRODUCT_MANAGER_RESPONDER_ARGS_JSON='["--auth","chatgpt-oauth","--codex-model","gpt-5.5"]'
SMITH_PRODUCT_MANAGER_RESPONDER_ENV_ALLOWLIST=
SMITH_PRODUCT_MANAGER_RESPONDER_CWD=
SMITH_PRODUCT_MANAGER_RESPONDER_TIMEOUT_SECS=

# The current workflow has a `human` role but the live secrets file may not. If
# no `human` credential exists, run the workflow human worker as this Forgejo
# user.
DOGFOOD_HUMAN_USER=bot

# Actual product-chat human author. This is separate from the workflow `human`
# role and must have a token in the private secrets note; no bot/admin fallback.
DOGFOOD_PRODUCT_CHAT_HUMAN_USER=free

# The mechanical worker uses this non-role identity when available; otherwise it
# falls back to the admin token used for setup.
DOGFOOD_MECHANICAL_USER=bot

# Optional non-workflow identity used by the example product-manager interaction
# profile. Normal dogfood workers do not require it; ./run.sh product-chat does.
DOGFOOD_PRODUCT_MANAGER_USER=product-manager
DOGFOOD_PRODUCT_CHAT_PROFILE_SPEC=
DOGFOOD_PRODUCT_CHAT_PROFILE_ID=product-manager
DOGFOOD_PRODUCT_CHAT_RESPONDER_ID=product-manager-responder

# Repo permission granted to role and optional product users by the setup step.
DOGFOOD_REPO_PERMISSION=write
DOGFOOD_DEFAULT_BRANCH=main

# CI workflow installation is explicit. Normal worker/product-chat startup does
# not commit .forgejo/workflows/ci.yml; set to 1 only for an intentional CI
# setup run.
DOGFOOD_CONFIGURE_CI=0

# Safety switch: keep off unless ./run.sh preflight reports every re-enable
# criterion as ok and a real dogfood issue is intentionally being implemented.
# With 0, the engineer worker and owner auto-merge worker are not launched.
DOGFOOD_ENABLE_ENGINEER_AUTOMATION=0

# Dogfood PR diff guard must stay active before engineer/owner automation can be
# enabled. There is no live-dogfood override for bookkeeping-only PRs; the second
# key exists so preflight can fail closed if an operator tries to opt out.
DOGFOOD_PR_DIFF_GUARD=1
DOGFOOD_ALLOW_BOOKKEEPING_ONLY_PR=0
DOGFOOD_PREFLIGHT_QUERY_ISSUES=1

# Optional local-git coding workspace binding for the engineer role. The command
# is an operator-configured provider, not a shell exposed to the LLM. It receives
# TEMPER_CODING_WORKSPACE_CONTEXT pointing at a JSON context file and must leave
# a meaningful non-.temper product diff for the worker to commit and push.
TEMPER_CODING_WORKSPACE_ROOT=
TEMPER_CODING_WORKSPACE_COMMAND=
TEMPER_CODING_WORKSPACE_REMOTE=origin
TEMPER_CODING_WORKSPACE_PUSH=1
TEMPER_CODING_WORKSPACE_PR_LABELS=implementation,needs-reviewer,needs-merge

# Spawn a local host-mode forgejo-runner against the live Forgejo instance.
# The registration token is parsed from the private secrets note.
DOGFOOD_RUNNER=1
DOGFOOD_REMOTE_FORGEJO_BIN=/opt/forgejo/forgejo
DOGFOOD_REMOTE_FORGEJO_WORK_PATH=/srv/data/git/forgejo

# Local development-profile binaries. Leave empty for target/debug defaults.
# run.sh runs `cargo build -p temper-production` unless TEMPER_SKIP_BUILD=1;
# this is Cargo's fast dev profile, not a release/production artifact.
TEMPER_WORKER_BIN=
TEMPER_TRIGGER_BIN=
TEMPER_INTERACTION_BIN=
TEMPER_FORGEJO_RUNNER_BINARY=
TEMPER_BUILD_PACKAGE=temper-production
