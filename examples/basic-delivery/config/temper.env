# basic-delivery example — operator-editable configuration (NO SECRETS).
#
# This file is sourced by run.sh. It carries only the knobs an operator may
# change; the launch script translates these into the production
# temper-daemon / smith-worker / temper-provision-forgejo CLI flags. CLI
# overrides always win over what is set here, which in turn overrides the
# binaries' own defaults.
#
# Secrets (per-role tokens/passwords, any API key) never live here — see
# ../secrets/ and ../secrets/.env.example.
#
# This is the "happy path, nothing fancy" counterpart to reference-delivery:
# ONE repo, architect + engineer worker capabilities, mechanical-as-bot in the
# daemon, CI, webhooks on, and landing gated on CI alone — no reviewer, owner, or
# human in the loop.

# --- Repository ---------------------------------------------------------------
# The example is deliberately single-repo. OWNER/NAME identify the one org+repo
# run.sh provisions, seeds, and scans. There is no REPOS set, no cross-repo
# fan-out, and no validators — keep it to one converging happy path.
OWNER=acme
NAME=service

# Default branch the repo is initialized with (the implementation PR targets it).
DEFAULT_BRANCH=main

# --- Workflow spec ------------------------------------------------------------
# The 3-role basic-delivery spec. run.sh passes this file to the provisioner and
# the daemon via Temper's --workflow flag. It tracks the canonical Temper fixture
# crates/temper-workflow/fixtures/basic-delivery.json — keep the two in sync; do
# not fork its semantics here.
#
# Path is resolved relative to this example's config/ directory by run.sh.
WORKFLOW_FILE=workflow.json

# --- Seeded intake issue ------------------------------------------------------
# The single intake issue the site admin (external filer) files. It is
# DELIBERATELY THIN: it declares only the overall intent, with no acceptance
# criteria, no setting name, and no implementation detail. That is the point of
# this example — the architect must rewrite this stub into a complete,
# implementable code spec during triage (the triage_intake_to_code set_body
# effect), proving it does real design/planning work rather than just relabeling.
# Do NOT pre-bake the design here; keep the body intent-only.
#
# INTAKE_BODY_FILE is resolved relative to this config/ directory by run.sh.
INTAKE_TITLE='Service banner should identify the environment'
INTAKE_BODY_FILE=intake-issue.md

# --- Forgejo + daemon endpoints ----------------------------------------------
# Where the bundled throwaway Forgejo server listens. The example boots its OWN
# server on the loopback interface; a known local port is a sane default. To
# target a real Forgejo, point BASE_URL at it and drop the bundled-server/
# provisioning steps (see the README "Point it at your own Forgejo").
BASE_URL=http://127.0.0.1:4100

# Where the single temper-daemon listens for both worker protocol traffic and the
# Forgejo webhook route. Leave WEBHOOK_URL empty to derive it from DAEMON_BIND;
# override only when Forgejo must reach the daemon through a different address.
DAEMON_BIND=127.0.0.1:38100
WEBHOOK_URL=

# Long role poll backstop so webhooks demonstrably drive progress; short
# mechanical cadence because Forgejo 7.0.x has no Actions-completion webhook and
# landing needs CI-read polling.
DAEMON_POLL_CADENCE_SECS=120
DAEMON_MECHANICAL_CADENCE_SECS=2
DAEMON_LEASE_TTL_SECS=300

# Hard backstop on how long the launcher blocks before tearing the run down.
RUN_SECS=600

# --- CPU cap (lesson 0009) ----------------------------------------------------
# The bundled Forgejo server (a Go program) can drive the host to several cores
# of sustained CPU under this multi-process workload. Cap GOMAXPROCS so the Go
# runtime cannot exceed this many cores. Set empty to opt out. Default 2.
TEMPER_FORGEJO_GOMAXPROCS=2

# --- Cached pinned binaries ---------------------------------------------------
# Absolute paths to the pinned Forgejo (7.0.12) and forgejo-runner (3.5.1)
# binaries. Leave empty to let the first run download + checksum them into
# .cache/forgejo/ (needs network to Codeberg / code.forgejo.org). On an
# offline/sandboxed host, pre-stage the binaries and point these at them.
TEMPER_FORGEJO_BINARY=
TEMPER_FORGEJO_RUNNER_BINARY=

# --- Temper entry-point binaries ---------------------------------------------
# The example targets Temper's operator-facing root-package entry points. Leave
# empty for the workspace target/debug defaults. TEMPER_BUILD_PACKAGE is the
# package run.sh builds in the development profile unless TEMPER_SKIP_BUILD=1.
TEMPER_DAEMON_BIN=
TEMPER_PROVISION_BIN=
TEMPER_BUILD_PACKAGE=temper

# --- Smith worker + anvil coding agent -----------------------------------------
# Smith supplies the orchestration worker tier; the coding agent is anvil-agent
# from the sibling anvil checkout, spawned out-of-process by the worker. Leave
# SMITH_WORKER_BIN empty for target/debug/smith-worker, ANVIL_WORKSPACE_ROOT
# empty for ../anvil. WORKER_MAX_CONCURRENT=1 keeps the demo deterministic.
SMITH_WORKSPACE_ROOT=
SMITH_WORKER_BIN=
ANVIL_WORKSPACE_ROOT=
WORKER_MAX_CONCURRENT=1

# BASIC_DELIVERY_CODER selects the coding executor's agent command:
#   anvil    (default) the real anvil-agent built from the sibling anvil
#            checkout, spawned by the worker via `--agent-command anvil-native`.
#            The engineer leaves a real product diff; the architect returns the
#            single `ready_code` verdict that routes the triage. Provider/auth
#            come from ANVIL_AGENT_ARGS (default `--auth chatgpt-oauth`).
#   greeting the deterministic stand-in (tools/greeting-coder.sh): a fixed
#            src/banner.sh diff and ready_code architect verdict, no LLM — for
#            an offline/CI smoke run of the full daemon/worker head path.
BASIC_DELIVERY_CODER=anvil
# Override the auto-built agent binary / its CLI args (provider + auth) when
# BASIC_DELIVERY_CODER=anvil. Empty uses anvil's built debug binary and
# `--auth chatgpt-oauth`.
ANVIL_AGENT_BIN=
ANVIL_AGENT_ARGS=

# For provider/auth setup, run anvil's documented preflight command (`anvil
# preflight`) from the anvil checkout and edit ANVIL_AGENT_ARGS / secrets/.env
# as needed. Temper and smith-worker do not read provider auth files or
# provider secrets.
