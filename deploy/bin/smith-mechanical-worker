#!/bin/sh
# smith-mechanical-worker — systemd ExecStart shim for the Smith basic-delivery
# mechanical worker, which runs as the `bot` automation user.
#
# Installed to ~/.local/bin by deploy/install.sh and invoked by
# smith-mechanical.service. Like smith-role-worker, it remaps the provisioned bot
# identity (TEMPER_FORGEJO_BOT_{USER,TOKEN,PASSWORD}, already in the environment
# via the unit's EnvironmentFile=) onto the generic vars temper-worker reads —
# something `Environment=` cannot do because it does not expand ${VAR}.
#
# The bot needs BOTH its REST token (to merge CI-green PRs) AND its web-UI
# username/password (the Forgejo 7.0.x CI-read fallback, ADR 0019). Nothing
# secret is placed on argv. POSIX sh only.

set -eu

[ -n "${TEMPER_FORGEJO_BOT_TOKEN:-}" ] || {
    printf 'smith-mechanical-worker: no TEMPER_FORGEJO_BOT_TOKEN in the environment; is ~/.config/smith/secrets/roles.env provisioned?\n' >&2
    exit 1
}

export TEMPER_FORGEJO_USERNAME="${TEMPER_FORGEJO_BOT_USER:-bot}"
export TEMPER_FORGEJO_TOKEN="$TEMPER_FORGEJO_BOT_TOKEN"
export TEMPER_FORGEJO_PASSWORD="${TEMPER_FORGEJO_BOT_PASSWORD:-}"

# Paths are pinned under $HOME to match the units' %h-based directives (the
# existing forgejo.service uses %h too). Keep this in step with the units.
exec "$HOME/.local/bin/temper-worker" \
    --backend forgejo --base-url "${BASE_URL}" --repo "${OWNER}/${NAME}" \
    --workflow "$HOME/.config/smith/workflow.json" \
    --kind mechanical \
    --poll-ms "${CI_STATUS_POLL_MS}" --idle-poll-max-ms "${IDLE_POLL_MAX_MS}" \
    --wake-socket "$HOME/.local/state/smith/wake/mechanical.sock" \
    --wake-secret-file "$HOME/.config/smith/secrets/wake-secret"
