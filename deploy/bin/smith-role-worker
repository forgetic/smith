#!/bin/sh
# smith-role-worker — systemd ExecStart shim for a Smith basic-delivery role
# worker (architect / engineer).
#
# Installed to ~/.local/bin by deploy/install.sh and invoked by
# smith-architect.service / smith-engineer.service as:
#     smith-role-worker <role>
#
# Why a shim: temper-worker reads its Forgejo credentials ONLY from the generic
# env vars TEMPER_FORGEJO_{TOKEN,USERNAME,PASSWORD} (secrets are never on argv),
# but the provisioned roles.env exports them under per-role suffixes
# (TEMPER_FORGEJO_{USER,TOKEN,PASSWORD}_<ROLE>). systemd's `Environment=` does NOT
# expand ${VAR}, so the remap cannot live in the unit file. This shim does it at
# runtime — the suffixed vars and all smith.env knobs are already in the
# environment via the units' EnvironmentFile= directives — then exec's the worker.
#
# All values arrive via the environment; nothing secret is placed on argv here.
# POSIX sh only.

set -eu

ROLE=${1:?usage: smith-role-worker <role>}

# Uppercase the role id and map non-alphanumerics to `_`, matching the
# provisioner's env_role_key (so `code-reviewer` -> CODE_REVIEWER, etc.).
KEY=$(printf '%s' "$ROLE" | tr '[:lower:]' '[:upper:]' | tr -c 'A-Z0-9' '_')

# Resolve the per-role identity from the suffixed vars provisioning wrote.
eval "ROLE_USER=\${TEMPER_FORGEJO_USER_${KEY}:-}"
eval "ROLE_TOKEN=\${TEMPER_FORGEJO_TOKEN_${KEY}:-}"
eval "ROLE_PASSWORD=\${TEMPER_FORGEJO_PASSWORD_${KEY}:-}"
[ -n "$ROLE_TOKEN" ] || {
    printf 'smith-role-worker: no TEMPER_FORGEJO_TOKEN_%s in the environment; is ~/.config/smith/secrets/roles.env provisioned?\n' "$KEY" >&2
    exit 1
}
[ -n "$ROLE_USER" ] || {
    printf 'smith-role-worker: no TEMPER_FORGEJO_USER_%s in the environment; is ~/.config/smith/secrets/roles.env provisioned?\n' "$KEY" >&2
    exit 1
}

# Export the generic credential names the worker actually reads.
export TEMPER_FORGEJO_USERNAME="$ROLE_USER"
export TEMPER_FORGEJO_TOKEN="$ROLE_TOKEN"
export TEMPER_FORGEJO_PASSWORD="$ROLE_PASSWORD"

# Provider/auth args for the role-decision responder (Smith-owned, never Forge
# tokens). Passed through from smith.env verbatim.
export TEMPER_WORKER_ROLE_DECISION_ARGS_JSON="${SMITH_WORKFLOW_ROLE_DECISION_ARGS_JSON:-}"

# Paths are pinned under $HOME to match the units' %h-based EnvironmentFile/
# Environment directives (the existing forgejo.service uses %h too). Keep this in
# step with the unit templates if those locations ever move.
exec "$HOME/.local/bin/temper-worker" \
    --backend forgejo --base-url "${BASE_URL}" --repo "${OWNER}/${NAME}" \
    --workflow "$HOME/.config/smith/workflow.json" \
    --kind role --role "$ROLE" --user "$ROLE_USER" \
    --role-decision-command "$HOME/.local/bin/smith-workflow-role-decision" \
    --poll-ms "${POLL_MS}" \
    --wake-socket "$HOME/.local/state/smith/wake/$ROLE.sock" \
    --wake-secret-file "$HOME/.config/smith/secrets/wake-secret"
