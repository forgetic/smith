# Smith basic-delivery deployment — operator-editable configuration (NO SECRETS).
#
# Installed to ~/.config/smith/smith.env by deploy/install.sh (never clobbered if
# you have already edited it). It is read as a systemd EnvironmentFile by every
# smith-*.service unit, so it is plain KEY=VALUE only — no shell expansion, no
# quoting tricks, no comments after a value.
#
# Secrets (per-role tokens/passwords, provider API keys) never live here — they
# are in ~/.config/smith/secrets/roles.env (0600, written by provisioning) and on
# Smith's own provider/auth surfaces.

# --- Repository ---------------------------------------------------------------
# The single repo the pool provisions, scans, and lands PRs in. This deployment
# dogfoods Smith against itself.
BASE_URL=http://127.0.0.1:3000
OWNER=ai
NAME=smith

# --- Worker cadence -----------------------------------------------------------
# Level-triggered poll interval for each role worker (--poll-ms), in ms. Keep it
# long: webhooks (via smith-trigger.service) are the latency accelerator, polling
# is the liveness backstop if a webhook is lost.
POLL_MS=120000

# The mechanical landing worker reads CI status on this SHORT poll because
# Forgejo 7.0.x does not webhook on Actions completion. After repeated idle ticks
# the cadence backs off to IDLE_POLL_MAX_MS; wakes still interrupt immediately.
CI_STATUS_POLL_MS=1000
IDLE_POLL_MAX_MS=8000

# --- Cargo resource limits ----------------------------------------------------
# Dogfood role workspaces may run cargo while Smith/Forgejo/CI are also active.
# Keep cargo serial in service environments to avoid OOM on small dev hosts.
CARGO_BUILD_JOBS=1

# --- Webhook trigger ----------------------------------------------------------
# Loopback bind for the local webhook accelerator (smith-trigger.service). Forge
# and trigger are both local — no ssh tunnel. The webhook registered on the repo
# during provisioning must point at this address's /forgejo/webhook path.
TRIGGER_BIND=127.0.0.1:38090

# --- Smith provider / auth ----------------------------------------------------
# Provider/auth options are Smith-owned and passed as opaque responder args, never
# on a public argv and never including Forge tokens. SMITH_WORKFLOW_ROLE_DECISION_ARGS_JSON
# is copied verbatim into TEMPER_WORKER_ROLE_DECISION_ARGS_JSON for the role
# workers; SMITH_CODING_AGENT_ARGS is appended to the smith-coding-agent command
# the engineer binds for its coding workspace. See docs/how-to/configure-provider-auth.md.
SMITH_WORKFLOW_ROLE_DECISION_ARGS_JSON=["--auth","chatgpt-oauth"]
SMITH_CODING_AGENT_ARGS=--auth chatgpt-oauth
