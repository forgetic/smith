# Smith consolidated worker deployment — operator-editable configuration (NO SECRETS).
#
# Installed to ~/.config/smith/smith.env by deploy/install.sh (never clobbered if
# you have already edited it). It is read as a systemd EnvironmentFile by
# smith-worker.service, so use plain KEY=VALUE lines — no shell expansion, no
# comments after a value.
#
# Per-role git credentials never live here. They stay in
# ~/.config/smith/secrets/roles.env as TEMPER_FORGEJO_{USER,TOKEN}_<ROLEKEY>
# (and optional TEMPER_FORGEJO_EMAIL_<ROLEKEY>) for smith-worker to read directly.
# Forge API tokens belong to the Temper daemon deployment, not this worker tier.

# --- Forge git base -----------------------------------------------------------
# Base URL used to build git remotes for the repos in WORKER_CAPABILITIES.
BASE_URL=http://127.0.0.1:3000

# --- Worker connection + capability registration -----------------------------
# Temper daemon URL. The daemon is deployed from the sibling temper/deploy/ tree.
WORKER_DAEMON_URL=http://127.0.0.1:8080

# Stable worker identity reported to the daemon.
WORKER_ID=smith-worker-1

# Space-separated owner/name:role pairs this worker can serve. Each role needs
# matching TEMPER_FORGEJO_USER_<ROLEKEY> and TEMPER_FORGEJO_TOKEN_<ROLEKEY> in
# secrets/roles.env.
WORKER_CAPABILITIES=ai/smith:engineer ai/temper:engineer

# Optional absolute workspace root for persistent per-(repo, role) checkouts.
# Leave blank to use ~/.local/state/smith/worker. systemd EnvironmentFile does
# not expand ~ or %h inside values, so set an absolute path if overriding.
WORKER_WORKSPACE_ROOT=

# Maximum jobs this worker runs concurrently.
WORKER_MAX_CONCURRENT=1

# Optional daemon long-poll wait and heartbeat intervals in milliseconds. Leave
# blank to use smith-worker defaults (30000 / 10000).
WORKER_POLL_WAIT_MS=
WORKER_HEARTBEAT_INTERVAL_MS=

# --- Cargo resource limits ----------------------------------------------------
# Dogfood workspaces may run cargo while Smith/Forgejo/CI are also active. Keep
# cargo serial in service environments to avoid OOM on small dev hosts.
CARGO_BUILD_JOBS=1

# --- Smith provider / auth ----------------------------------------------------
# Provider/auth options passed to smith-coding-agent. Keep Forge credentials out
# of this value; workers already read git credentials from secrets/roles.env.
SMITH_CODING_AGENT_ARGS=--auth chatgpt-oauth
