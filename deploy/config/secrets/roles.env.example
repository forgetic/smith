# TEMPLATE — do not fill in by hand and do not commit a real copy.
#
# The LIVE ~/.config/smith/secrets/roles.env is written (0600) by the Temper
# provisioner, NOT by the install script. See docs/how-to/provision-smith-dogfood.md
# step 2 and docs/how-to/run-local-delivery.md. This example only documents the
# shape smith-worker.service expects.
#
# Sourced as a systemd EnvironmentFile, so plain KEY=VALUE only (no shell quoting).
# The provisioner writes single-quoted values; systemd reads those quotes fine.

# --- Per-role identities ------------------------------------------------------
# One USER/TOKEN/PASSWORD triple per LLM role. smith-worker reads the suffixed
# TEMPER_FORGEJO_{USER,TOKEN}_<ROLEKEY> vars directly (role_identities_from_env);
# an optional TEMPER_FORGEJO_EMAIL_<ROLEKEY> overrides the commit email
# (default <user>@noreply.localhost). The worker uses the token only for git
# push, never for the Forge API.
TEMPER_FORGEJO_USER_ARCHITECT=architect
TEMPER_FORGEJO_TOKEN_ARCHITECT=REPLACED_BY_PROVISIONER
TEMPER_FORGEJO_PASSWORD_ARCHITECT=REPLACED_BY_PROVISIONER

TEMPER_FORGEJO_USER_ENGINEER=engineer
TEMPER_FORGEJO_TOKEN_ENGINEER=REPLACED_BY_PROVISIONER
TEMPER_FORGEJO_PASSWORD_ENGINEER=REPLACED_BY_PROVISIONER

# --- bot automation identity --------------------------------------------------
# Mechanical landing now runs inside the Temper daemon (its deployment holds the
# bot's API credentials); these stay here only because provisioning writes them
# into the same file. The worker tier does not read them.
TEMPER_FORGEJO_BOT_USER=bot
TEMPER_FORGEJO_BOT_TOKEN=REPLACED_BY_PROVISIONER
TEMPER_FORGEJO_BOT_PASSWORD=REPLACED_BY_PROVISIONER
